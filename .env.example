FEDEX_BASE_URL=https://apis-sandbox.fedex.com
FEDEX_ACCOUNT_NUMBER=123456789
FEDEX_API_KEY=your_fedex_api_key
FEDEX_API_SECRET=your_fedex_api_secret

# Opcional: ativa persistencia em PostgreSQL quando "pg" estiver instalado
DATABASE_URL=postgres://usuario:senha@localhost:5432/xml_converter

# Opcional: intervalo do worker local em milissegundos
WORKER_POLL_MS=1000

# Opcional: protege endpoints operacionais e de reprocessamento
OPS_API_TOKEN=change_me

# Opcional: smoke test operacional contra API ja em execucao
SMOKE_API_BASE_URL=http://127.0.0.1:3000
SMOKE_TIMEOUT_MS=30000
SMOKE_POLL_INTERVAL_MS=1000
# Valores uteis: completed | failed | retry_scheduled | any_terminal
SMOKE_EXPECT_STATUS=any_terminal

# Opcional: observabilidade com Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
